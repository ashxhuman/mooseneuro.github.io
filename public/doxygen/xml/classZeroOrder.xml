        <type><ref refid="classRateTerm" kindref="compound">RateTerm</ref> *</type>
        <definition>RateTerm * ZeroOrder::copyWithVolScaling</definition>
        <argsstring>(double vol, double sub, double prd) const</argsstring>
        <name>copyWithVolScaling</name>
        <qualifiedname>ZeroOrder::copyWithVolScaling</qualifiedname>
        <reimplements refid="classRateTerm_1a1ed45d040641861c18c1e896c2512e90">copyWithVolScaling</reimplements>
