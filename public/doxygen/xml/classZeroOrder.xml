        <type>void</type>
        <definition>void ZeroOrder::rescaleVolume</definition>
        <argsstring>(short comptIndex, const vector&lt; short &gt; &amp;compartmentLookup, double ratio)</argsstring>
        <name>rescaleVolume</name>
        <qualifiedname>ZeroOrder::rescaleVolume</qualifiedname>
