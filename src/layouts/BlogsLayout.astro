---
import Hero from "../components/Hero.astro";
import BaseLayout from "./BaseLayout.astro";

const {
  title = "Blogs",
  image,
  url,
  showHero = true,
  heroTitle = "Blogs",
} = Astro.props;
---

<BaseLayout
  title={title}
  image={image}
  url={url}
  ogType="article"
>
  <slot />
</BaseLayout>